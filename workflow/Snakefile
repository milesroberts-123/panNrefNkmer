# load samples
reads = pd.read_table(
    "../config/samples.tsv", sep="\t", dtype={"Run": str}
).set_index(["Run"], drop=False)

#validate(parameters, "../config/parameters.schema.yaml")

# Define rules too fast to bother with cluster submission
localrules: all, batch_per_sample

