rule kmers_only:
    input:
     expand("kmer_distances_{species}.txt", species = reads["Species"].unique())

rule batch_per_sample:
    input:
        expand("bcftools_linref_results/{ID}_{ref}_{split}.vcf.gz", ID = reads["BioSample"], ref = config["linrefs"], split = range(10, 10 + config["splits"])),
        expand("cbf_results/{ID}.txt", ID = reads["BioSample"]),
        expand("salmon_quant_results/{ref}_{rna}/quant.sf", ref = config["linrefs"], rna = config["rna"])

