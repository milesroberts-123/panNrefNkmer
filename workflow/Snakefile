# load packages

import pandas as pd
import os
from snakemake.utils import min_version

min_version("9.5.1")

# configuration
configfile: "../config/config.yaml"


# load samples
reads = pd.read_table(
    "../config/samples.tsv", sep="\t", dtype={"Run": str}
).set_index(["Run"], drop=False)

# Define rules too fast to bother with cluster submission
localrules: all, batch_per_sample

rule all:
    input:
        expand("results/samtools_stats/{ID}_{ref}.txt", ID = reads["BioSample"], ref = config["linrefs"]),
        expand("results/bcftools_stats/{ref}.txt", ref = config["linrefs"]),
        expand("results/mk_test_{ref}/mk.tsv", ref = config["linrefs"]),
        expand("results/salmon_quantmerge/{ref}.txt", ref = config["linrefs"]),
        expand("results/pixy/{ref}_{stat}.txt", ref = config["linrefs"], stat = ["pi", "watterson_theta", "tajima_d", "dxy", "fst"]),
        expand("results/kmer_distances_{species}.txt", species = reads["Species"].unique()),
        "results/multiqc/multiqc_report.html"

rule jules_only:
    input:
        expand("results/psmc/{srr}.psmc", srr = reads["Run"]),
        expand("results/roh/{srr}_ROH.txt", srr = reads["Run"])

rule kmers_only:
    input:
     expand("results/kmer_distances_{species}.txt", species = reads["Species"].unique())

rule batch_per_sample:
    input:
        expand("results/bcftools_linref/{ID}_{ref}_{split}.vcf.gz", ID = reads["BioSample"], ref = config["linrefs"], split = range(10, 10 + config["splits"])),
        expand("results/cbf/{ID}.txt", ID = reads["BioSample"]),
        expand("results/salmon_quant/{ref}_{rna}/quant.sf", ref = config["linrefs"], rna = config["rna"])

## Jules branch
include: "rules/jules.smk"

## Data download and QC rules
include: "rules/data_download.smk"
include: "rules/fastp.smk"
include: "rules/multiqc.smk"
include: "rules/change_headers.smk"

## Linear alignment rules
include: "rules/bwa.smk"

## SAM tools rules
include: "rules/samtools.smk"

## K-mer counting rules
include: "rules/kmc.smk"
include: "rules/cbf.smk"

## Pangenome graph building and alignment rules
include: "rules/pggb.smk"
include: "rules/vg.smk"

## Gene expression quantification
include: "rules/salmon.smk"

## Population genetics summary rules
include: "rules/degenotate.smk"
include: "rules/pixy.smk"

## Split sites
include: "rules/split.smk"

## Mash k-mer distances
include: "rules/mash.smk"
